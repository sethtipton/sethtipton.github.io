---
import InternalLink from './InternalLink.astro';
import type { ResumeEntry } from '../../lib/resume';
import { getExternalLinkProps, isOutboundHref } from '../../lib/links';
import {
  getResumeLink,
  getResumePdfHref,
  getResumePrintHref,
  RESUME_PDF_FILE_NAME,
} from '../../lib/resume';
import WorkHistoryItem from './WorkHistoryItem.astro';
import '../../styles/resume.scss';

interface Props {
  resume: ResumeEntry;
  variant?: 'page' | 'print';
}

const { resume, variant = 'page' } = Astro.props;
const base = import.meta.env.BASE_URL;
const isPrint = variant === 'print';
const isDev = import.meta.env.DEV;
const pdfHref = getResumePdfHref(base);
const printHref = getResumePrintHref(base);
---

<article
  class:list={['resume-document flow-xl', isPrint && 'resume-document--print']}
  aria-labelledby="resume-title"
>
  <header class="resume-document__header">
    <div class="resume-document__identity flow-sm">
      <h1 id="resume-title" class="resume-document__name">
        {resume.data.name}
      </h1>
      <p class="resume-document__role">{resume.data.role}</p>
      <p class="resume-document__location">{resume.data.location}</p>
    </div>

    <address class="resume-document__contact-block">
      <ul class="resume-document__contacts" aria-label="Contact information">
        {
          resume.data.contacts.map((item) => {
            const href = getResumeLink(item, base);

            return (
              <li class="resume-document__contact">
                <span class="resume-document__contact-label">
                  {item.label}:
                </span>
                {isOutboundHref(href) ? (
                  <a href={href} {...getExternalLinkProps(href)}>
                    {item.text}
                  </a>
                ) : (
                  <InternalLink href={href}>{item.text}</InternalLink>
                )}
              </li>
            );
          })
        }
      </ul>
    </address>
  </header>

  {
    !isPrint && (
      <div class="resume-document__actions">
        <div class="button-row">
          {!isDev ? (
            <a
              class="button-link"
              href={pdfHref}
              download={RESUME_PDF_FILE_NAME}
            >
              Download PDF
            </a>
          ) : (
            <p class="resume-document__pdf-note text-muted">
              PDF download is generated by the build. Use the print-friendly
              view while running the dev server.
            </p>
          )}
          <InternalLink
            class="button-link button-link--secondary"
            href={printHref}
          >
            Print-friendly view
          </InternalLink>
        </div>
      </div>
    )
  }

  <section
    class="resume-document__section flow"
    aria-labelledby="profile-title"
  >
    <div class="resume-document__section-heading">
      <h2 id="profile-title">Profile</h2>
    </div>

    <p class="resume-document__profile">{resume.data.profile}</p>
  </section>

  <section
    class="resume-document__section flow"
    aria-labelledby="experience-title"
  >
    <div class="resume-document__section-heading">
      <h2 id="experience-title">Experience</h2>
    </div>

    <div class="experience-list">
      {
        resume.data.experience.map((item) => (
          <WorkHistoryItem item={item} interactive={!isPrint} />
        ))
      }
    </div>
  </section>

  <section class="resume-document__section flow" aria-labelledby="skills-title">
    <div class="resume-document__section-heading">
      <h2 id="skills-title">Skills</h2>
    </div>

    <ul class="resume-skill-list" aria-label="Skills">
      {
        resume.data.skills.map((group) => (
          <li class="resume-skill pdf-entry">
            <h3>{group.category}</h3>
            <p>{group.items.join(', ')}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section
    class="resume-document__section flow"
    aria-labelledby="education-title"
  >
    <div class="resume-document__section-heading">
      <h2 id="education-title">Education</h2>
    </div>

    <ul class="resume-education-list" aria-label="Education">
      {
        resume.data.education.map((item) => (
          <li class="resume-education pdf-entry">
            <h3>{item.school}</h3>
            <p>{item.degree}</p>
          </li>
        ))
      }
    </ul>
  </section>
</article>
