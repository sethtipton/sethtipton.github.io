---
import SocialIcon from './SocialIcon.astro';
import SiteSignature from './SiteSignature.astro';
import InternalLink from './InternalLink.astro';
import StyleTransferMount from './StyleTransferMount.astro';
import { primaryNav, siteMeta, socialLinks } from '../../data/site';
import { getExternalLinkProps, resolveHref } from '../../lib/links';
import { withBase } from '../../lib/paths';

type SocialIconName = 'GitHub' | 'LinkedIn' | 'Email';

const base = import.meta.env.BASE_URL;
const normalizePath = (path: string) =>
  path.endsWith('/') ? path : `${path}/`;
const currentPath = normalizePath(Astro.url.pathname);
const navLinks = primaryNav.map((item) => ({
  ...item,
  href: withBase(item.href, base),
}));
const headerLinks = socialLinks.slice(0, 3).map((item) => ({
  ...item,
  href: resolveHref(item, base),
  icon: item.label as SocialIconName,
}));
---

<header class="site-header" data-site-header>
  <div class="container site-header__inner">
    <InternalLink
      class="site-brand"
      href={withBase('/', base)}
      aria-label={siteMeta.title}
    >
      <SiteSignature />
    </InternalLink>

    <nav class="site-header__primary" aria-label="Primary">
      <ul class="site-nav">
        {
          navLinks.map((item) => {
            const href = normalizePath(item.href);
            const active =
              href === withBase('/', base)
                ? currentPath === href
                : currentPath.startsWith(href);

            return (
              <li>
                <InternalLink
                  href={item.href}
                  aria-current={active ? 'page' : undefined}
                >
                  {active ? (
                    <span
                      class="site-nav__chip site-nav__chip--active"
                      transition:name="site-nav-active-chip"
                      transition:animate="initial"
                    >
                      <span class="site-nav__active-pill" aria-hidden="true" />
                      <span class="site-nav__label">{item.label}</span>
                    </span>
                  ) : (
                    <span class="site-nav__chip">
                      <span class="site-nav__label">{item.label}</span>
                    </span>
                  )}
                </InternalLink>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <ul class="site-header__links" aria-label="External links">
      {
        headerLinks.map((item) => (
          <li>
            <a
              class="social-link social-link--header"
              href={item.href}
              aria-label={item.label}
              title={item.label}
              {...getExternalLinkProps(item.href)}
            >
              <SocialIcon name={item.icon} />
            </a>
          </li>
        ))
      }
    </ul>

    <div class="site-header__style-transfer">
      <StyleTransferMount />
    </div>
  </div>
</header>

<script>
  import { initializeSiteHeaderState } from '../../lib/headerBehavior';

  initializeSiteHeaderState();
</script>
