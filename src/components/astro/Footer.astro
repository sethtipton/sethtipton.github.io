---
import HeroPattern from './HeroPattern.astro';
import InternalLink from './InternalLink.astro';
import SocialIcon from './SocialIcon.astro';
import {
  availabilityNote,
  contactLinks,
  primaryNav,
  siteMeta,
} from '../../data/site';
import {
  getExternalLinkProps,
  isOutboundHref,
  resolveHref,
} from '../../lib/links';
import { withBase } from '../../lib/paths';

type SocialIconName = 'GitHub' | 'LinkedIn' | 'Email';

const base = import.meta.env.BASE_URL;
const normalizePath = (path: string) =>
  path.endsWith('/') ? path : `${path}/`;
const currentPath = normalizePath(Astro.url.pathname);
const resolvedContactLinks = contactLinks.map((item) => ({
  ...item,
  href: resolveHref(item, base),
}));
const footerNavLinks = primaryNav.map((item) => ({
  ...item,
  href: withBase(item.href, base),
}));
const footerContactLinks = resolvedContactLinks
  .filter((item) => item.href !== withBase('/resume/', base))
  .map((item) => ({
    ...item,
    icon: item.label as SocialIconName,
  }));
---

<footer class="site-footer">
  <HeroPattern variant="footer" trigger="view" />

  <div class="container site-footer__inner">
    <div class="flow-sm">
      <InternalLink class="site-brand" href={withBase('/', base)}>
        {siteMeta.title}
      </InternalLink>
      <p class="text-muted">{siteMeta.description}</p>
      <p class="text-muted">{availabilityNote}</p>
    </div>

    <div class="site-footer__meta">
      <nav aria-label="Footer">
        <ul class="link-list" aria-label="Primary pages">
          {
            footerNavLinks.map((item) => {
              const href = normalizePath(item.href);
              const active =
                href === withBase('/', base)
                  ? currentPath === href
                  : currentPath.startsWith(href);

              return (
                <li>
                  <InternalLink
                    href={item.href}
                    aria-current={active ? 'page' : undefined}
                  >
                    {item.label}
                  </InternalLink>
                </li>
              );
            })
          }
        </ul>
      </nav>

      <address class="site-footer__contact">
        <ul class="link-list" aria-label="Contact links">
          {
            footerContactLinks.map((item) => (
              <li>
                {isOutboundHref(item.href) ? (
                  <a href={item.href} {...getExternalLinkProps(item.href)}>
                    <SocialIcon name={item.icon} />
                    {item.label}
                  </a>
                ) : (
                  <InternalLink href={item.href}>
                    <SocialIcon name={item.icon} />
                    {item.label}
                  </InternalLink>
                )}
              </li>
            ))
          }
        </ul>
      </address>
    </div>
  </div>
</footer>
