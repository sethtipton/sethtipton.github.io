<script>
  import { gsap } from 'gsap';
  import {
    getRuntimeStyleTransferMotionProfile,
    motionMsToSeconds,
  } from '../../lib/style-transfer/motion';

  const enhancerWindow = window as typeof window & {
    __caseStudyHoverEnhancerBound?: boolean;
  };

  const initializeCaseStudyHover = () => {
    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;
    const supportsDesktopHover = window.matchMedia(
      '(hover: hover) and (pointer: fine)',
    ).matches;
    const hasTouchPointer = window.matchMedia('(any-pointer: coarse)').matches;

    // Touch-capable devices keep the static scrim/panel fallback instead.
    if (prefersReducedMotion || !supportsDesktopHover || hasTouchPointer) {
      return;
    }

    const cards = document.querySelectorAll<HTMLElement>(
      '[data-case-study-hover-card]',
    );

    cards.forEach((card) => {
      if (card.dataset.hoverEnhancerBound === 'true') {
        return;
      }

      const panel = card.querySelector<HTMLElement>(
        '[data-case-study-hover-panel]',
      );
      const scrim = card.querySelector<HTMLElement>(
        '[data-case-study-hover-scrim]',
      );
      const image = card.querySelector<HTMLElement>(
        '[data-case-study-hover-image]',
      );
      const visualLink = card.querySelector<HTMLAnchorElement>(
        '.project-visual__link',
      );
      const paths = Array.from(
        card.querySelectorAll<SVGPathElement>('[data-case-study-hover-path]'),
      );

      if (!panel || !scrim || !image || paths.length === 0) {
        return;
      }

      card.dataset.hoverEnhancerBound = 'true';

      const lengths = paths.map((path) => {
        const length = path.getTotalLength();

        path.style.strokeDasharray = `${length}`;
        path.style.strokeDashoffset = `${length}`;

        return length;
      });

      card.classList.add('project-visual--interactive-ready');

      gsap.set(paths, {
        opacity: 1,
        strokeWidth: 200,
      });
      gsap.set(scrim, { opacity: 0 });
      gsap.set(panel, {
        autoAlpha: 0,
        y: getRuntimeStyleTransferMotionProfile(document.documentElement)
          .distances.md,
      });
      gsap.set(image, { scale: 1, transformOrigin: '50% 50%' });

      let active = false;

      const collapseImmediately = () => {
        const motion = getRuntimeStyleTransferMotionProfile(
          document.documentElement,
        );
        active = false;
        card.classList.remove('project-visual--hover-active');
        card.classList.remove('project-visual--focus-static');

        gsap.killTweensOf([scrim, panel, image, ...paths]);
        gsap.set(image, { scale: 1 });
        gsap.set(scrim, { opacity: 0 });
        gsap.set(paths, {
          strokeDashoffset: (index: number) => lengths[index] ?? 0,
          strokeWidth: 100,
        });
        gsap.set(panel, {
          autoAlpha: 0,
          y: motion.distances.md,
        });
      };

      const enter = () => {
        const motion = getRuntimeStyleTransferMotionProfile(
          document.documentElement,
        );

        if (!motion.decorativeEnabled) {
          collapseImmediately();
          return;
        }

        if (active) {
          return;
        }

        active = true;
        card.classList.remove('project-visual--focus-static');
        card.classList.add('project-visual--hover-active');

        gsap.killTweensOf([scrim, panel, image, ...paths]);
        gsap.to(image, {
          scale: 1.04,
          duration: motionMsToSeconds(motion.durations.viewSlow),
          ease: motion.easings.standard.gsap,
        });
        gsap.to(scrim, {
          opacity: 1,
          duration: motionMsToSeconds(motion.durations.medium),
          ease: motion.easings.standard.gsap,
        });
        gsap.to(paths, {
          strokeDashoffset: 0,
          strokeWidth: 700,
          duration: motionMsToSeconds(
            motion.durations.viewSlow + motion.durations.medium,
          ),
          ease: motion.easings.emphasized.gsap,
          stagger: motionMsToSeconds(motion.stagger.sm),
        });
        gsap.to(panel, {
          autoAlpha: 1,
          y: 0,
          duration: motionMsToSeconds(motion.durations.enter),
          delay: motionMsToSeconds(motion.stagger.md * 3),
          ease: motion.easings.emphasized.gsap,
        });
      };

      const revealForFocus = () => {
        active = true;
        card.classList.add('project-visual--hover-active');
        card.classList.add('project-visual--focus-static');

        gsap.killTweensOf([scrim, panel, image, ...paths]);
        gsap.set(image, {
          scale: 1,
        });
        gsap.set(scrim, {
          opacity: 1,
        });
        gsap.set(paths, {
          opacity: 0,
          strokeDashoffset: (index: number) => lengths[index] ?? 0,
          strokeWidth: 100,
        });
        gsap.set(panel, {
          autoAlpha: 1,
          y: 0,
        });
      };

      const leave = () => {
        const motion = getRuntimeStyleTransferMotionProfile(
          document.documentElement,
        );
        active = false;
        card.classList.remove('project-visual--hover-active');
        card.classList.remove('project-visual--focus-static');
        gsap.killTweensOf([scrim, panel, image, ...paths]);
        gsap.to(image, {
          scale: 1,
          duration: motionMsToSeconds(motion.durations.slow),
          ease: motion.easings.standard.gsap,
        });
        gsap.to(scrim, {
          opacity: 0,
          duration: motionMsToSeconds(motion.durations.exit),
          ease: motion.easings.exit.gsap,
        });
        gsap.to(paths, {
          opacity: 1,
          strokeDashoffset: (_, target) => {
            const index = paths.indexOf(target as SVGPathElement);
            return lengths[index] ?? 0;
          },
          strokeWidth: 100,
          duration: motionMsToSeconds(motion.durations.viewMedium),
          ease: motion.easings.exit.gsap,
          stagger: motionMsToSeconds(motion.stagger.sm * 0.75),
        });
        gsap.to(panel, {
          autoAlpha: 0,
          y: motion.distances.md,
          duration: motionMsToSeconds(motion.durations.exit),
          ease: motion.easings.exit.gsap,
        });
      };

      card.addEventListener('mouseenter', enter);
      card.addEventListener('mouseleave', leave);
      card.addEventListener('focusin', revealForFocus);
      card.addEventListener('focusout', (event) => {
        const next = event.relatedTarget;

        if (next instanceof Node && card.contains(next)) {
          return;
        }

        collapseImmediately();
      });

      if (visualLink) {
        visualLink.addEventListener('pointerdown', collapseImmediately);
        visualLink.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            collapseImmediately();
          }
        });
      }
    });
  };

  initializeCaseStudyHover();

  if (!enhancerWindow.__caseStudyHoverEnhancerBound) {
    document.addEventListener('astro:page-load', initializeCaseStudyHover);
    enhancerWindow.__caseStudyHoverEnhancerBound = true;
  }
</script>
