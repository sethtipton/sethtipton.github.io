---
import CaseStudyCard from '../components/astro/CaseStudyCard.astro';
import CaseStudyHoverEnhancer from '../components/astro/CaseStudyHoverEnhancer.astro';
import HeroPattern from '../components/astro/HeroPattern.astro';
import InternalLink from '../components/astro/InternalLink.astro';
import Section from '../components/astro/Section.astro';
import StyleTransferHeroArtwork from '../components/react/StyleTransferHeroArtwork';
import WorkHistoryItem from '../components/astro/WorkHistoryItem.astro';
import { buildPrinciples } from '../data/experience';
import { contactLinks, heroContent } from '../data/site';
import {
  getExternalLinkProps,
  isOutboundHref,
  resolveHref,
} from '../lib/links';
import { getFeaturedProjects } from '../lib/projects';
import { getResume } from '../lib/resume';
import { withBase } from '../lib/paths';
import BaseLayout from '../layouts/BaseLayout.astro';

const featuredProjects = await getFeaturedProjects(4);
const resume = await getResume();
const [oracleExperience, boondockExperience] = resume.data.experience;
const homeExperience = [
  {
    ...oracleExperience,
    bullets: [
      oracleExperience.bullets[0],
      oracleExperience.bullets[2],
      oracleExperience.bullets[5],
    ],
  },
  boondockExperience,
];
const base = import.meta.env.BASE_URL;
const contactSortOrder = ['Email', 'LinkedIn', 'GitHub', 'Resume'];
const resolvedContactLinks = contactLinks
  .map((item) => ({
    ...item,
    href: resolveHref(item, base),
  }))
  .sort(
    (left, right) =>
      contactSortOrder.indexOf(left.label) -
      contactSortOrder.indexOf(right.label),
  );
const homeMeta = {
  title:
    'Front-end platform systems, shared UI infrastructure, and product engineering',
  description:
    'Seth Tipton leads front-end platform work: navigation, shared components, CMS integration, and product UI that needs strong standards.',
} as const;
---

<BaseLayout title={homeMeta.title} description={homeMeta.description}>
  <section class="section-shell hero">
    <HeroPattern />
    <StyleTransferHeroArtwork client:load />

    <div class="container hero__grid">
      <div class="flow-lg">
        <div class="flow-sm">
          <h1>{heroContent.title}</h1>
        </div>

        <div class="flow">
          {
            heroContent.statement.map((paragraph) => (
              <p class="lead">{paragraph}</p>
            ))
          }
        </div>

        <div class="button-row">
          {
            heroContent.ctas.map((item, index) => (
              <InternalLink
                class={
                  index === 0
                    ? 'button-link'
                    : 'button-link button-link--secondary'
                }
                href={withBase(item.href, base)}
              >
                {item.label}
              </InternalLink>
            ))
          }
        </div>
      </div>

      <aside class="surface-card hero-panel flow" aria-label="Best fit">
        <p class="eyebrow eyebrow--muted">Best fit</p>
        <h2 class="h3size">
          Shared platform and product UI work built around systems that are
          reliable, safe to evolve, and durable across teams and workflows.
        </h2>
        <ul class="stack-list">
          <li>
            Navigation, component systems, and CMS-backed UI with clear
            ownership and safer rollouts
          </li>
          <li>
            Accessibility, performance, standards, and mentoring that keep
            shared systems healthy over time
          </li>
          <li>
            Delivery focused on simpler architecture, safer releases, and
            careful AI use within a strong QA process
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <Section
    id="selected-work"
    eyebrow="Selected case studies"
    title="Case studies in navigation platforms, shared component systems, and front-end modernization under real delivery constraints."
    description="Each one focuses on the work behind durable UI: reuse, rollout safety, accessibility, and maintainability across teams."
  >
    <div class="section-actions">
      <InternalLink class="inline-link" href={withBase('/work/', base)}>
        See all case studies
      </InternalLink>
    </div>

    <div class="case-study-grid">
      {
        featuredProjects.map((project) => (
          <CaseStudyCard project={project} hoverMeta={true} />
        ))
      }
    </div>

    <CaseStudyHoverEnhancer />
  </Section>

  <Section
    id="how-i-build"
    eyebrow="How I lead the work"
    title="I do my best work where front-end needs both system thinking and hands-on delivery."
    description="The throughline is making complex UI easier to ship, test, and extend without lowering standards."
    contrast={true}
  >
    <ol class="principles-list">
      {
        buildPrinciples.map((principle) => (
          <li class="surface-card surface-hover principle-card flow-sm">
            <h3>{principle.title}</h3>
            <p class="text-muted">{principle.summary}</p>
          </li>
        ))
      }
    </ol>
  </Section>

  <Section
    id="work-history"
    eyebrow="Recent roles"
    title="Recent roles span enterprise navigation, agency delivery, and front-end stewardship that holds up after launch."
  >
    <div class="experience-grid">
      {
        homeExperience.map((item, index) => (
          <WorkHistoryItem item={item} bulletLimit={2} compact={index > 0} />
        ))
      }
    </div>

    <div class="section-actions">
      <InternalLink
        class="button-link button-link--secondary"
        href={withBase('/resume/', base)}
      >
        See full resume
      </InternalLink>
    </div>
  </Section>

  <Section
    id="contact"
    eyebrow="Let's talk"
    title="Best fit: senior and staff front-end roles centered on platform systems, design systems, and durable product UI."
    description="I’m most interested in teams that need architecture judgment, delivery standards, and hands-on implementation in the same role."
  >
    <div class="contact-panel surface-card flow">
      <address class="contact-panel__address">
        <ul class="contact-grid" aria-label="Contact links">
          {
            resolvedContactLinks.map((item) => (
              <li>
                {isOutboundHref(item.href) ? (
                  <a
                    class="contact-link surface-hover"
                    href={item.href}
                    {...getExternalLinkProps(item.href)}
                  >
                    <span>{item.label}</span>
                    <span aria-hidden="true">↗</span>
                  </a>
                ) : (
                  <InternalLink
                    class="contact-link surface-hover"
                    href={item.href}
                  >
                    <span>{item.label}</span>
                    <span aria-hidden="true">→</span>
                  </InternalLink>
                )}
              </li>
            ))
          }
        </ul>
      </address>
    </div>
  </Section>
</BaseLayout>
