---
import CaseStudyCard from '../../components/astro/CaseStudyCard.astro';
import CaseStudyHoverEnhancer from '../../components/astro/CaseStudyHoverEnhancer.astro';
import InternalLink from '../../components/astro/InternalLink.astro';
import { withBase } from '../../lib/paths';
import { getProjects } from '../../lib/projects';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = await getProjects();
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Work"
  description="Case studies in shared infrastructure, product complexity, and pragmatic front-end modernization."
>
  <section class="page-shell">
    <div class="container flow-xl">
      <header class="page-intro page-intro--wide flow">
        <h1>Selected case studies.</h1>
        <p class="lead">
          These projects show how I handle shared infrastructure, CMS-heavy
          builds, and rollout risk in ways that reduce forks, make publishing
          easier, and keep releases safer across teams.
        </p>
        <div class="button-row">
          <InternalLink
            class="button-link button-link--secondary"
            href={withBase('/resume/', base)}
          >
            View resume
          </InternalLink>
        </div>
      </header>

      <h2 class="sr-only">All case studies</h2>
      <div class="case-study-grid">
        {
          projects.map((project, index) => (
            <CaseStudyCard
              project={project}
              hoverMeta={true}
              priority={index < 2}
            />
          ))
        }
      </div>

      <CaseStudyHoverEnhancer />
    </div>
  </section>
</BaseLayout>
