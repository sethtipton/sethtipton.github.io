---
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/astro/Footer.astro';
import Header from '../components/astro/Header.astro';
import { siteMeta } from '../data/site';
import { withBase } from '../lib/paths';
import '../styles/global.scss';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  socialImage?: string;
  robots?: string;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  ogType = 'website',
  socialImage,
  robots = 'index,follow',
} = Astro.props;
const themeColor = siteMeta.themeColor;

const pageTitle =
  title === siteMeta.title ? title : `${title} | ${siteMeta.title}`;
const base = import.meta.env.BASE_URL;
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.toString();
const socialImageUrl =
  Astro.site && socialImage
    ? new URL(socialImage, Astro.site).toString()
    : undefined;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? siteMeta.url;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    description: siteMeta.description,
    inLanguage: 'en-US',
    name: siteMeta.title,
    url: siteUrl,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    email: `mailto:${siteMeta.email}`,
    jobTitle: siteMeta.jobTitle,
    name: siteMeta.title,
    sameAs: siteMeta.sameAs,
    url: siteUrl,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={themeColor.light} />
    <link
      rel="icon"
      href={withBase('/favicon.svg', base)}
      sizes="any"
      type="image/svg+xml"
    />
    <link
      rel="icon"
      href={withBase('/favicon-32x32.png', base)}
      sizes="32x32"
      type="image/png"
    />
    <link
      rel="apple-touch-icon"
      href={withBase('/apple-touch-icon.png', base)}
    />
    <link rel="manifest" href={withBase('/site.webmanifest', base)} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={siteMeta.title} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {socialImageUrl && <meta property="og:image" content={socialImageUrl} />}
    {socialImageUrl && <meta property="og:image:alt" content={pageTitle} />}
    <meta
      name="twitter:card"
      content={socialImageUrl ? 'summary_large_image' : 'summary'}
    />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}
    {socialImageUrl && <meta name="twitter:image:alt" content={pageTitle} />}
    <title>{pageTitle}</title>
    <ClientRouter />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
    <script>
      import { initializeSiteShell } from '../lib/siteShell';

      initializeSiteShell();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
